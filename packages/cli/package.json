{
  "name": "@taskcast/cli",
  "version": "1.0.0",
  "description": "Standalone Taskcast server CLI — run with npx taskcast.",
  "repository": {
    "type": "git",
    "url": "https://github.com/weightwave/taskcast.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/weightwave/taskcast/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/weightwave/taskcast/issues"
  },
  "license": "MIT",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "bin": {
    "taskcast": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^0.19.10",
    "hono": "^4.6.0",
    "@taskcast/core": "workspace:*",
    "@taskcast/dashboard-web": "workspace:*",
    "@taskcast/playground": "workspace:*",
    "@taskcast/postgres": "workspace:*",
    "@taskcast/redis": "workspace:*",
    "@taskcast/server": "workspace:*",
    "@taskcast/sqlite": "workspace:*",
    "commander": "^12.1.0",
    "ioredis": "^5.4.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
